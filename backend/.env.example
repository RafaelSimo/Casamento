# ===========================================
# Configurações do Site - Casamento Alleane & Rafael
# ===========================================

# Porta do servidor
PORT=3000

# URL base do site (sem barra no final)
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seudominio.com.br
BASE_URL=casamentorafaealle.up.railway.app

# ===========================================
# Banco de Dados PostgreSQL
# ===========================================
# No Railway, a variável DATABASE_URL é preenchida automaticamente!
# Para desenvolvimento local, instale PostgreSQL ou use ElephantSQL/Neon
DATABASE_URL=postgresql://usuario:senha@localhost:5432/casamento

# ===========================================
# Mercado Pago - Credenciais
# ===========================================
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
# USE AS CREDENCIAIS DE PRODUÇÃO QUANDO FOR AO AR!
MP_ACCESS_TOKEN=TEST-0000000000000000-000000-00000000000000000000000000000000-000000000
MP_PUBLIC_KEY=TEST-00000000-0000-0000-0000-000000000000

# ===========================================
# PIX Manual (chave PIX dos noivos)
# ===========================================
PIX_KEY=aaa
PIX_NAME=CasamentoAlleRafa
PIX_CITY=MANAUS

# ===========================================
# Segurança
# ===========================================
# Chave secreta para tokens JWT (MUDE ISSO!)
JWT_SECRET=senha secreta

# Credenciais do painel admin (serão criadas no primeiro acesso)
ADMIN_USER=rafaelalleane
ADMIN_PASSWORD=tobybaby

# ===========================================
# CORS - Origens permitidas
# ===========================================
CORS_ORIGIN=*

# ===========================================
# Cloudinary (storage gratuito de imagens)
# ===========================================
# Crie conta grátis em: https://cloudinary.com/
# Acesse o Dashboard para pegar as credenciais
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
